#!/bin/bash
#
# HELIX Mission Control — CLI Management Tool
# Usage: helix <command> [args]
#
# Commands:
#   status                  Show all service statuses
#   logs [service]          Tail logs (backend|frontend|gateway|db|redis|all)
#   restart [service]       Restart services (or all)
#   stop                    Stop all services
#   start                   Start all services
#   backup                  Run immediate backup
#   restore <file>          Restore from backup file
#   restore --latest        Restore most recent backup
#   health                  Run health check
#   update                  Pull latest code + rebuild + migrate
#   reset-password <email>  Reset a user's password
#   create-token <name>     Generate a new service token
#   agents                  List all agents and their status
#   db migrate              Run pending database migrations
#   db shell                Open PostgreSQL shell
#   config                  Show current configuration (secrets masked)
#   version                 Show HELIX version info

set -uo pipefail

# === Find project directory ===
if [ -f "$HOME/helix-mission-control/.env" ]; then
    PROJECT_DIR="$HOME/helix-mission-control"
elif [ -f "/home/helix/helix-mission-control/.env" ]; then
    PROJECT_DIR="/home/helix/helix-mission-control"
else
    echo "ERROR: Cannot find HELIX installation. Expected at ~/helix-mission-control/"
    exit 1
fi

cd "$PROJECT_DIR"

# === Load .env ===
if [ -f .env ]; then
    set +e
    set -a
    source .env 2>/dev/null
    set +a
    set -uo pipefail
fi

# === Colors ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# === Commands ===

cmd_status() {
    echo -e "${CYAN}HELIX Mission Control — Status${NC}"
    echo "================================"
    echo ""

    # Docker services
    echo -e "${BLUE}Docker Services:${NC}"
    docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || \
        docker compose ps

    echo ""

    # Host gateway
    echo -e "${BLUE}Host Gateway:${NC}"
    if systemctl --user is-active openclaw-gateway > /dev/null 2>&1; then
        echo -e "  openclaw-gateway: ${GREEN}running${NC}"
    elif systemctl --user is-enabled openclaw-gateway 2>/dev/null; then
        echo -e "  openclaw-gateway: ${RED}stopped${NC}"
    else
        echo -e "  openclaw-gateway: ${YELLOW}not configured${NC}"
    fi

    echo ""

    # API health
    echo -e "${BLUE}API Health:${NC}"
    local HEALTH=$(curl -sf http://localhost:8000/api/health 2>/dev/null)
    if [ -n "$HEALTH" ]; then
        echo -e "  Backend: ${GREEN}ok${NC}"
        echo "  $HEALTH" | python3 -m json.tool 2>/dev/null || echo "  $HEALTH"
    else
        echo -e "  Backend: ${RED}not responding${NC}"
    fi

    echo ""

    # System resources
    echo -e "${BLUE}System Resources:${NC}"
    echo "  RAM:  $(free -h | awk '/^Mem:/{printf "%s used / %s total (%s free)", $3, $2, $7}')"
    echo "  Swap: $(free -h | awk '/^Swap:/{printf "%s used / %s total", $3, $2}')"
    echo "  Disk: $(df -h / | tail -1 | awk '{printf "%s used / %s total (%s free, %s)", $3, $2, $4, $5}')"

    echo ""

    # Domain
    echo -e "${BLUE}Access:${NC}"
    if [ "${ENABLE_SSL:-false}" = "true" ] && [ -n "${DOMAIN:-}" ]; then
        echo "  URL: https://${DOMAIN}"
    elif [ -n "${DOMAIN:-}" ]; then
        echo "  URL: http://${DOMAIN}"
    else
        echo "  URL: http://$(curl -s ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'):3000"
    fi

    # Backup info
    echo ""
    echo -e "${BLUE}Backups:${NC}"
    local BDIR="/backups"
    [ ! -d "$BDIR" ] && BDIR="$HOME/backups"
    local BACKUP_COUNT=$(ls "$BDIR"/helix-*.tar.gz 2>/dev/null | wc -l)
    local LATEST=$(ls -t "$BDIR"/helix-*.tar.gz 2>/dev/null | head -1)
    echo "  Total: $BACKUP_COUNT backups"
    if [ -n "$LATEST" ]; then
        echo "  Latest: $(basename "$LATEST") ($(du -h "$LATEST" | cut -f1))"
    fi
}

cmd_logs() {
    local SERVICE="${1:-all}"
    if [ "$SERVICE" = "all" ]; then
        docker compose logs -f --tail=100
    elif [ "$SERVICE" = "gateway-host" ]; then
        journalctl --user -u openclaw-gateway -f
    else
        docker compose logs -f --tail=100 "$SERVICE"
    fi
}

cmd_restart() {
    local SERVICE="${1:-}"
    if [ -z "$SERVICE" ]; then
        echo "Restarting all services..."
        docker compose restart
        if systemctl --user is-enabled openclaw-gateway 2>/dev/null; then
            systemctl --user restart openclaw-gateway
        fi
    else
        echo "Restarting $SERVICE..."
        if [ "$SERVICE" = "gateway-host" ]; then
            systemctl --user restart openclaw-gateway
        else
            docker compose restart "$SERVICE"
        fi
    fi
    echo -e "${GREEN}Done${NC}"
}

cmd_stop() {
    echo "Stopping all services..."
    docker compose down
    echo -e "${GREEN}All services stopped${NC}"
}

cmd_start() {
    echo "Starting all services..."
    docker compose up -d
    echo -e "${GREEN}All services started${NC}"
}

cmd_backup() {
    bash scripts/backup.sh
}

cmd_restore() {
    bash scripts/restore.sh "$@"
}

cmd_health() {
    bash scripts/health-check.sh
}

cmd_update() {
    bash scripts/update.sh
}

cmd_reset_password() {
    local EMAIL="${1:-}"
    if [ -z "$EMAIL" ]; then
        echo "Usage: helix reset-password <email>"
        exit 1
    fi

    local NEW_PASSWORD=$(openssl rand -base64 12 | tr -d '=+/')
    echo "Resetting password for: $EMAIL"

    docker compose exec -T backend python3 -c "
import asyncio
from app.db.session import async_session
from app.models.user import User
from app.core.security import get_password_hash
from sqlalchemy import select

async def reset():
    async with async_session() as db:
        result = await db.execute(select(User).where(User.email == '$EMAIL'))
        user = result.scalar_one_or_none()
        if not user:
            print('ERROR: User not found')
            return
        user.password_hash = get_password_hash('$NEW_PASSWORD')
        await db.commit()
        print(f'Password reset successfully')
        print(f'New password: $NEW_PASSWORD')
        print(f'User must change this on next login')

asyncio.run(reset())
"
}

cmd_create_token() {
    local NAME="${1:-api-token}"
    local TOKEN=$(openssl rand -base64 48 | tr -d '=+/' | head -c 64)

    echo "Creating service token: $NAME"
    echo "Token: $TOKEN"
    echo ""
    echo "Add this to your API requests as:"
    echo "  Authorization: Bearer $TOKEN"
    echo ""
    echo -e "${YELLOW}Save this token now — it cannot be retrieved again.${NC}"

    # Register in database
    docker compose exec -T backend python3 -c "
import asyncio, hashlib
from app.db.session import async_session
from app.models.service_token import ServiceToken
from uuid import uuid4

async def create():
    async with async_session() as db:
        from sqlalchemy import select
        from app.models.organization import Organization
        org = await db.execute(select(Organization).limit(1))
        org = org.scalar_one_or_none()
        if not org:
            print('ERROR: No organization found')
            return

        token = ServiceToken(
            id=uuid4(),
            org_id=org.id,
            name='$NAME',
            token_hash=hashlib.sha256('$TOKEN'.encode()).hexdigest(),
            token_prefix='$TOKEN'[:8],
        )
        db.add(token)
        await db.commit()
        print('Token registered in database')

asyncio.run(create())
" 2>/dev/null || echo "Note: Could not register token in DB. Add manually via settings page."
}

cmd_agents() {
    echo -e "${CYAN}HELIX Agents${NC}"
    echo "============"

    curl -sf http://localhost:8000/api/agents/ \
        -H "Authorization: Bearer ${SERVICE_TOKEN:-}" 2>/dev/null | \
    python3 -c "
import sys, json
try:
    agents = json.load(sys.stdin)
    if isinstance(agents, dict):
        agents = agents.get('agents', agents.get('data', []))
    for a in agents:
        name = a.get('name', '?')
        status = a.get('status', '?')
        role = a.get('role_title', '')
        icon = '🟢' if status == 'online' else '🔴' if status == 'error' else '⚪'
        print(f'  {icon} {name:<15} {status:<10} {role}')
    print(f'\nTotal: {len(agents)} agents')
except Exception as e:
    print(f'Could not fetch agents: {e}')
" 2>/dev/null || echo "Could not fetch agents. Is the backend running?"
}

cmd_db() {
    local SUBCMD="${1:-}"
    case "$SUBCMD" in
        migrate)
            echo "Running database migrations..."
            docker compose exec -T backend alembic upgrade head
            echo -e "${GREEN}Migrations complete${NC}"
            ;;
        shell)
            echo "Opening PostgreSQL shell (\\q to exit)..."
            docker compose exec db psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-mission_control}"
            ;;
        *)
            echo "Usage: helix db <migrate|shell>"
            ;;
    esac
}

cmd_config() {
    echo -e "${CYAN}HELIX Configuration${NC}"
    echo "==================="
    echo ""
    if [ -f .env ]; then
        # Show config with secrets masked
        sed -E 's/(PASSWORD|SECRET|TOKEN|API_KEY)=.{4}(.+)/\1=****\2/' .env | \
        sed -E 's/(PASSWORD|SECRET|TOKEN|API_KEY)=\*\*\*\*.{4}(.*)/\1=********/' | \
        grep -v "^#" | grep -v "^$" | sort
    else
        echo "No .env file found"
    fi
}

cmd_version() {
    echo -e "${CYAN}HELIX Mission Control${NC}"
    echo "  Version: $(git describe --tags --always 2>/dev/null || echo 'dev')"
    echo "  Commit:  $(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
    echo "  Branch:  $(git branch --show-current 2>/dev/null || echo 'unknown')"
    echo "  Path:    $PROJECT_DIR"
}

cmd_help() {
    cat << 'EOF'

  HELIX Mission Control — CLI

  Usage: helix <command> [args]

  Commands:
    status                  Show service statuses and system info
    logs [service]          Tail logs (backend|frontend|gateway|db|redis|all|gateway-host)
    restart [service]       Restart one or all services
    stop                    Stop all services
    start                   Start all services
    backup                  Run immediate backup
    restore <file>          Restore from backup (or --latest)
    health                  Run health check
    update                  Pull latest + rebuild + migrate
    reset-password <email>  Reset a user's password
    create-token <name>     Generate new service token
    agents                  List all agents and status
    db migrate              Run pending migrations
    db shell                Open PostgreSQL shell
    config                  Show configuration (secrets masked)
    version                 Show version info

EOF
}

# === Route Command ===
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    status)         cmd_status ;;
    logs)           cmd_logs "$@" ;;
    restart)        cmd_restart "$@" ;;
    stop)           cmd_stop ;;
    start)          cmd_start ;;
    backup)         cmd_backup ;;
    restore)        cmd_restore "$@" ;;
    health)         cmd_health ;;
    update)         cmd_update ;;
    reset-password) cmd_reset_password "$@" ;;
    create-token)   cmd_create_token "$@" ;;
    agents)         cmd_agents ;;
    db)             cmd_db "$@" ;;
    config)         cmd_config ;;
    version)        cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $COMMAND"
        cmd_help
        exit 1
        ;;
esac
