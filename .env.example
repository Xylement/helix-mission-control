# ============================================================
# HELIX Mission Control — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required fields are marked with [REQUIRED]
# Auto-generated fields are marked with [AUTO] — install.sh fills these
# ============================================================

# === Organization ===
ORG_NAME=MyCompany
ADMIN_EMAIL=admin@example.com                    # [REQUIRED] First admin login email
ADMIN_PASSWORD=change-me-on-first-login          # [REQUIRED] First admin password

# === AI Model (BYOK — Bring Your Own Key) ===
MODEL_PROVIDER=moonshot                          # [REQUIRED] moonshot | openai | anthropic | nvidia | kimi-coding | custom
MODEL_NAME=kimi-k2.5                             # Model identifier for the provider
MODEL_API_KEY=sk-your-key-here                   # [REQUIRED] Your AI model API key
MODEL_BASE_URL=                                  # Leave blank for auto-detect, or set custom endpoint
MODEL_DISPLAY_NAME=                              # Friendly name (defaults to MODEL_NAME)
MODEL_CONTEXT_WINDOW=256000                      # Max context window tokens
MODEL_MAX_TOKENS=8192                            # Max output tokens per request

# === Gateway ===
GATEWAY_PORT=18789                               # OpenClaw Gateway WebSocket port
GATEWAY_TOKEN=                                   # [AUTO] Gateway authentication token
GATEWAY_URL=ws://gateway:18789                   # Internal Docker URL (don't change unless custom setup)

# === Telegram (Optional) ===
TELEGRAM_BOT_TOKEN=                              # BotFather token (leave blank to skip)
TELEGRAM_ALLOWED_USER_IDS=                       # Comma-separated Telegram user IDs

# === Domain & SSL ===
DOMAIN=localhost                                 # Your domain or IP address
ENABLE_SSL=false                                 # Set to true if using a domain with SSL
SSL_EMAIL=                                       # Email for Let's Encrypt certificate
SKIP_PROXY=false                                 # Set true if using external Nginx/proxy

# === Database ===
POSTGRES_USER=helix
POSTGRES_PASSWORD=                               # [AUTO] Auto-generated secure password
POSTGRES_DB=helix_mc
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Authentication ===
AUTH_MODE=local
JWT_SECRET=                                      # [AUTO] Auto-generated JWT signing key
SERVICE_TOKEN=                                   # [AUTO] Service token for API integrations (Telegram, external)

# === Frontend ===
NEXT_PUBLIC_API_URL=auto                         # 'auto' detects from browser, or set explicit URL
NEXT_PUBLIC_API_BASE_URL=                        # Leave blank for default
BACKEND_URL=http://backend:8000                  # Used by Next.js API proxy rewrite (internal Docker URL)

# === CORS ===
CORS_ORIGINS=http://localhost:3000               # Comma-separated allowed origins

# === Analytics (Optional) ===
GA4_PROPERTY_ID=
GSC_SITE_URL=
GOOGLE_APPLICATION_CREDENTIALS=

# === Advanced ===
LOG_LEVEL=info                                   # debug | info | warning | error
MAX_AGENTS=50                                    # Max agents per organization
GENERATE_CONFIG=true                             # Generate openclaw.json from env vars (set false to use mounted config)

# === License ===
LICENSE_SERVER_URL=https://api.helixnode.tech
LICENSE_KEY=                                      # Your HELIX license key (e.g. HLX-XXXX-XXXX-XXXX-XXXX)

# === Legacy (leave blank — kept for compatibility) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
